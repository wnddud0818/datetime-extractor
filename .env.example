# 공공데이터포털 특일 정보 API 서비스 키 (선택)
# https://www.data.go.kr/data/15012690/openapi.do 에서 발급
# 없어도 src/calendar/holidays-fallback.json 번들 데이터로 동작합니다
HOLIDAY_API_KEY=

# Ollama 엔드포인트 (기본값: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# 사용할 LLM 모델 (기본: qwen2.5:3b-instruct)
OLLAMA_MODEL=qwen2.5:3b-instruct
